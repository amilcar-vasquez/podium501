# ─── Required ───────────────────────────────────────────────────────────────

# Public origin of your deployed app (no trailing slash).
# adapter-node uses this for CSRF / host checking.
ORIGIN=https://your-app.railway.app

# ─── Database ────────────────────────────────────────────────────────────────

# Absolute path to the SQLite database file.
# Point this at a Railway Volume mount so data survives redeploys.
# Railway Volume setup:
#   1. Dashboard → your service → Volumes → Add Volume
#   2. Mount path: /data
#   3. Set DB_PATH=/data/podium501.db here
DB_PATH=/data/podium501.db

# ─── Coach PINs ──────────────────────────────────────────────────────────────

# JSON map of PIN → Coach Name.  Keep this secret — set it in the Railway
# environment variables panel, not in a committed file.
# Example:
# COACH_PINS_JSON={"2346":"Amilcar","1000":"Myron","1001":"Coach Dulce"}
COACH_PINS_JSON=
